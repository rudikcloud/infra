POSTGRES_DB=rudikcloud
POSTGRES_USER=rudik
POSTGRES_PASSWORD=rudik
POSTGRES_PORT=5432
REDIS_PORT=6379
AUTH_SERVICE_PORT=8001
DASHBOARD_PORT=3000
FLAGS_SERVICE_PORT=8003
AUDIT_SERVICE_PORT=8004
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
OTEL_COLLECTOR_OTLP_GRPC_PORT=4317
OTEL_COLLECTOR_OTLP_HTTP_PORT=4318
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_SERVICE_VERSION=0.1.0
OTEL_ENVIRONMENT=local
OTEL_TRACES_SAMPLER=always_on
AUTH_DATABASE_URL=postgresql://rudik:rudik@postgres:5432/rudikcloud
AUTH_REDIS_URL=redis://redis:6379/0
AUTH_JWT_SECRET=dev-only-change-me
AUTH_JWT_ISSUER=rudikcloud-auth
AUTH_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_SESSION_COOKIE_NAME=auth_session
AUTH_SESSION_TTL_SECONDS=86400
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:8001
ORDERS_DATABASE_URL=postgresql://rudik:rudik@postgres:5432/rudikcloud
ORDERS_REDIS_URL=redis://redis:6379/0
ORDERS_EVENTS_STREAM=orders.events
ORDERS_AUTH_SERVICE_URL=http://auth-service:8000
ORDERS_AUTH_REQUEST_TIMEOUT_SECONDS=5
ORDERS_FLAGS_SERVICE_URL=http://flags-service:8000
ORDERS_FLAGS_REQUEST_TIMEOUT_SECONDS=5
ORDERS_AUDIT_REQUEST_TIMEOUT_SECONDS=5
FLAGS_DATABASE_URL=postgresql://rudik:rudik@postgres:5432/rudikcloud
FLAGS_AUTH_SERVICE_URL=http://auth-service:8000
FLAGS_AUTH_REQUEST_TIMEOUT_SECONDS=5
FLAGS_AUDIT_REQUEST_TIMEOUT_SECONDS=5
AUDIT_DATABASE_URL=jdbc:postgresql://postgres:5432/rudikcloud?user=rudik&password=rudik
AUDIT_INGEST_TOKEN=dev-audit-token
AUDIT_SERVICE_URL=http://audit-service-java:8000
NOTIFICATIONS_DATABASE_URL=postgresql://rudik:rudik@postgres:5432/rudikcloud
NOTIFICATIONS_REDIS_URL=redis://redis:6379/0
NOTIFICATIONS_ORDERS_EVENTS_STREAM=orders.events
NOTIFICATIONS_ORDERS_RETRY_ZSET=orders.retry
NOTIFICATIONS_ORDERS_DLQ_STREAM=orders.dlq
NOTIFICATIONS_MAX_ATTEMPTS=5
NOTIFICATIONS_WORKER_POLL_INTERVAL_MS=500
NOTIFICATIONS_FAIL_MODE=off
